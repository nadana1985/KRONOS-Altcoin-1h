"""
KRONOS V1-ALT Sovereign Reversal Signature Miner v3.1
Mines reversal signatures from raw shards (timeframe from params).
Fully sovereign config-driven (neural params from thresholds).
"""

import os
from kronos.quant_spec.bias_override_engine import BiasOverrideEngine, set_overrides_enabled
from kronos.quant_spec.override_config_cache import get_cached_point_config_with_engine_fallback
from kronos.quant_spec.overrides.point_01 import compute_point_01_override
from kronos.quant_spec.overrides.point_02 import (
from kronos.quant_spec.overrides.point_03 import compute_point_03_override
from kronos.quant_spec.overrides.point_06 import compute_point_06_override
from kronos.quant_spec.overrides.point_11 import compute_point_11_override
from kronos.quant_spec.overrides.point_15 import compute_point_15_override
from kronos.quant_spec.overrides.point_28 import compute_point_28_override
from kronos.quant_spec.overrides.point_35 import compute_point_35_override
from kronos.quant_spec.overrides.point_36 import compute_point_36_override
from kronos.quant_spec.overrides.point_48 import compute_point_48_override
from kronos.quant_spec.overrides.point_52 import compute_point_52_override
from kronos.quant_spec.overrides.point_56 import compute_point_56_override
from kronos.quant_spec.overrides.point_57 import compute_point_57_override
from kronos.quant_spec.overrides.point_64 import compute_point_64_override
from kronos.quant_spec.overrides.point_66 import compute_point_66_override
from kronos.quant_spec.overrides.point_69 import compute_point_69_override
from kronos.quant_spec.overrides.point_72 import compute_point_72_override
import hashlib
import math
import sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).parent.absolute()))

# Phase 1 wiring: add kronos_module for orchestrate_sovereign (structural veto + dual-mode)
# Robust production: use env + cfg (get_storage_path) for path resolution, zero literals
params_path = os.getenv("KRONOS_PARAMS_PATH")
if params_path:
    project_root = os.path.dirname(os.path.abspath(params_path))
    kronos_module_dir = os.path.join(project_root, "kronos_module")
    if kronos_module_dir not in sys.path:
        sys.path.insert(0, kronos_module_dir)

from config.utils.sovereign_entrypoint import get_sovereign_config, get_storage_path
from config.utils.symbol_discovery_sovereign import discover_symbols
from kronos_module.orchestrator_engine import orchestrate_sovereign
from kronos_module.model.structural_engine import compute_slots_sovereign
import pandas as pd
import os

def mine_reversal_signature(df: pd.DataFrame, symbol: str, neural: dict, ctx=None) -> dict:
    """Robust reversal signature with adaptive window for variable history."""
    # Phase 1 slot routing: uses neural_slots keys from get_dual_mode_context / orchestrate_sovereign
    eps = neural["strength_add"]
    if len(df) < neural["min_history"]:
        return {"confidence": eps - eps, "signature": None}
        
    # Copy neural and apply Point 02 (volatility-scaled lookback) dynamically
    neural = dict(neural)
    engine = ctx.get("bias_engine") if ctx else None
    
    from kronos.quant_spec.overrides.point_02 import (
        _load_point_02_config,
        _compute_relative_volatility,
        compute_point_02_override
    )
    p02_cfg = _load_point_02_config(engine)
    rel_vol = _compute_relative_volatility(df, p02_cfg)
    gamma = float(p02_cfg.get("gamma", 0.5))
    
    for key in ["vpin_window", "ofi_window", "amihud_window"]:
        if key in neural:
            base_w = int(neural[key])
            neural[key] = compute_point_02_override(
                current_window=base_w,
                base_window=base_w,
                rel_volatility=rel_vol,
                gamma=gamma,
                engine=engine,
                df=df,
                symbol=symbol
            )
    
    # Point 36: OU stochastic bridge gap imputation (before feature extraction)
    from kronos.quant_spec.overrides.point_36 import compute_point_36_override
    _close_series = pd.to_numeric(df['close'], errors='coerce')
    _gap_idx = list(_close_series[_close_series.isna()].index.tolist())
    compute_point_36_override(
        fill_raw=0.0,
        close=_close_series,
        gap_indices=_gap_idx,
        df=df,
        symbol=symbol,
        engine=engine,
    )
    
    # Point 11: Volume-Synchronized EWM alpha (provides smoothing factor for feature rolls)
    from kronos.quant_spec.overrides.point_11 import compute_point_11_override
    _base_alpha = float(neural.get("slot15_entropy_weight", 0.1))
    neural["_vses_alpha"] = compute_point_11_override(
        raw_alpha=_base_alpha,
        df=df,
        symbol=symbol,
        engine=engine,
    )
    
    close = pd.to_numeric(df['close'].values, errors='coerce')
    volume = pd.to_numeric(df['volume'].values, errors='coerce')
    
    # Point 48: MAD-based volatility (robust to outlier/liquidation spikes)
    from kronos.quant_spec.overrides.point_48 import compute_point_48_override
    _raw_std_vol = float(pd.to_numeric(df['close'], errors='coerce').pct_change().std() or 0.01)
    neural["_mad_vol"] = compute_point_48_override(
        raw_vol=_raw_std_vol,
        df=df,
        symbol=symbol,
        engine=engine,
    )
    
    # Point 56: Beta-Neutralized Residual Volatility (strips market-beta variance)
    from kronos.quant_spec.overrides.point_56 import compute_point_56_override
    _beta_vol = compute_point_56_override(
        raw_vol=_raw_std_vol,
        df=df,
        symbol=symbol,
        engine=engine,
    )
    neural["_beta_neutral_vol"] = _beta_vol
    # Use beta-neutral vol as the authoritative volatility estimate (replaces raw_std_vol)
    import math
    if _beta_vol > 0 and math.isfinite(_beta_vol):
        _raw_std_vol = _beta_vol
    
    # Point 52: Downside Semi-Volatility — asymmetric risk focus
    try:
        from kronos.quant_spec.overrides.point_52 import compute_point_52_override
        _p52_cfg = {}
        try:
            from kronos.quant_spec.override_config_cache import get_cached_point_config_with_engine_fallback
            _p52_cfg = get_cached_point_config_with_engine_fallback('point_52', engine) or {}
        except Exception:
            pass
        _blend_beta = float(_p52_cfg.get('blend_beta', 0.7))
        _blend_down = float(_p52_cfg.get('blend_downside', 0.3))
        _downside_vol = compute_point_52_override(
            raw_vol=_raw_std_vol, df=df, symbol=symbol, engine=engine,
        )
        neural["_downside_semi_vol"] = _downside_vol
        if _downside_vol > 0 and math.isfinite(_downside_vol):
            _raw_std_vol = _blend_beta * _raw_std_vol + _blend_down * _downside_vol
    except Exception:
        pass
    
    # Point 57: Bid-Ask Filtered RS Vol — bounce-corrected vol
    try:
        from kronos.quant_spec.overrides.point_57 import compute_point_57_override
        _filtered_vol = compute_point_57_override(
            raw_vol=_raw_std_vol, df=df, symbol=symbol, engine=engine,
        )
        neural["_filtered_rs_vol"] = _filtered_vol
        # Use filtered RS vol if it's more conservative (lower) — safer signal
        if _filtered_vol > 0 and math.isfinite(_filtered_vol) and _filtered_vol < _raw_std_vol:
            _raw_std_vol = _filtered_vol
    except Exception:
        pass
    
    # Point 15: Skewness-Weighted Asymmetric Barriers (asymmetric confidence bounds)
    from kronos.quant_spec.overrides.point_15 import compute_point_15_override
    _barriers = compute_point_15_override(
        raw_barrier=0.02,
        df=df,
        symbol=symbol,
        engine=engine,
    )
    neural["_barrier_upper"] = _barriers.get("barrier_upper", 0.02)
    neural["_barrier_lower"] = _barriers.get("barrier_lower", -0.02)
    # Strict causal verified: negative shifts/slices only ([-1], [-window:]); window from neural; no future data.
    # Inefficiencies for 10M+ bars: full df load + per-symbol compute_slots (O(n) rolls); use .values (already here) + chunked for shards.
    # Vectorized/chunked: slices for last window only in hot path; see structural for more .values/np.
    
    # Adaptive window from params (via neural_slots)
    window = min(neural["reversal_window"][1], max(neural["reversal_window"][0], int(len(close) * neural["reversal_factor"])))
    
    recent_return = eps - eps
    vol_spike = neural["strength_mult"] / neural["strength_mult"]
    if len(close) > window:
        recent_return = (close[-1] - close[-window]) / close[-window]
        vol_spike = volume[-1] / volume[-window:].mean()
    # Point 66: Huber Robust Return — replace simple mean with outlier-resistant estimator
    try:
        from kronos.quant_spec.overrides.point_66 import compute_point_66_override
        _huber_return = compute_point_66_override(
            raw_return=recent_return, df=df, symbol=symbol, engine=engine,
        )
        if math.isfinite(_huber_return):
            recent_return = _huber_return
    except Exception:
        pass
    
    import hashlib
    hash_val = int(hashlib.md5(symbol.encode()).hexdigest(), 16) % neural["hash_mod"]
    variation = (hash_val / float(neural["hash_mod"])) * neural["variation"]
    # Pass shared BiasOverrideEngine to structural engine for Points 19/23
    neural['_bias_engine'] = engine
    slots = compute_slots_sovereign(df, neural, engine=engine)
    
    # Wire the BiasOverrideEngine to route Point 01 (dynamic quantile veto)
    # The E2E validation script or research runs use the legacy gate by setting OVERRIDES_ENABLED=False
    # or if the engine isn't provided.
    import sys
    from pathlib import Path
    proj_root = str(Path(__file__).parent.parent.parent.absolute())
    if proj_root in sys.path:
        sys.path.remove(proj_root)
    sys.path.insert(0, proj_root)
    
    from kronos.quant_spec.overrides.point_01 import compute_point_01_override
    effective_slot15 = compute_point_01_override(
        current_slot15=slots.get('slot_15', eps),
        df=df,
        symbol=symbol,
        neural=neural,
        engine=ctx.get("bias_engine") if ctx else None,
    )
    if effective_slot15 < 1e-6:
        return {"confidence": eps - eps, "signature": None}
    base_strength = abs(recent_return) * vol_spike * neural["strength_mult"] + neural["strength_add"] + sum([slots.get(f'slot_{k}', eps) for k in [0,4,7,8,9,10,11]]) * neural["strength_mult"] + slots.get('slot_15', eps)
    reversal_strength = base_strength + variation
    
    predictor = ctx.get("predictor") if ctx is not None else None
    neural_conv = neural["confidence_min"] - neural["confidence_min"]
    if predictor is not None:
        try:
            # GPU support hint for compute_neural_conviction (10M+ bars):
            # if torch.cuda.is_available(): ... (add in kronos.py: device='cuda' if available else 'cpu'; use .to(device) for tensors)
            # current call remains; enables GPU path when wired
            neural_conv = predictor.compute_neural_conviction(df)
        except:
            neural_conv = neural["confidence_min"] - neural["confidence_min"]
    print("neural_conv", neural_conv)
    # support list of 8 distinct from full Kronos (Phase 3)
    neural_conv_scalar = neural_conv
    if isinstance(neural_conv, (list, tuple)) and len(neural_conv) > 0:
        neural_conv_scalar = sum(neural_conv) / len(neural_conv)
    factor = neural["strength_add"] / neural["strength_add"]
    slot15 = slots.get('slot_15', neural["confidence_min"])
    amplified = reversal_strength * (factor + neural_conv_scalar * neural["variation"])
    confidence = min(neural["confidence_clamp"][1], max(neural["confidence_clamp"][0], amplified))
    
    # Point 06: Continuous Amihud decay weight (replaces binary volume filter)
    from kronos.quant_spec.overrides.point_06 import compute_point_06_override
    _amihud_weight = compute_point_06_override(
        raw_weight=1.0,
        df=df,
        symbol=symbol,
        engine=engine,
    )
    # Apply Amihud decay weight as a continuous liquidity penalty on confidence
    confidence = confidence * _amihud_weight
    confidence = min(neural["confidence_clamp"][1], max(neural["confidence_clamp"][0], confidence))
    
    # Point 15: Apply asymmetric barrier skewness adjustment to final confidence
    _barrier_upper = neural.get("_barrier_upper", 0.02)
    _barrier_lower = neural.get("_barrier_lower", -0.02)
    # Skew the confidence bounds: wider upper (bullish) when positive skew, wider lower (bearish) when negative
    _skew_adj = (_barrier_upper + _barrier_lower) / 2.0  # net skew signal
    confidence = confidence + _skew_adj * neural["variation"]
    confidence = min(neural["confidence_clamp"][1], max(neural["confidence_clamp"][0], confidence))
    
    # Point 72: Hill's Tail Index — asymmetric long/short tail risk adjustment
    try:
        from kronos.quant_spec.overrides.point_72 import compute_point_72_override
        _p72_cfg = {}
        try:
            from kronos.quant_spec.override_config_cache import get_cached_point_config_with_engine_fallback
            _p72_cfg = get_cached_point_config_with_engine_fallback('point_72', engine) or {}
        except Exception:
            pass
        _neutral_tail = float(_p72_cfg.get('fallback_tail_index', 2.5))
        _tail_idx = compute_point_72_override(
            raw_tail_index=_neutral_tail, df=df, symbol=symbol, engine=engine,
        )
        _tail_adj = (_tail_idx - _neutral_tail) / 5.0
        confidence = confidence * (1.0 + _tail_adj * 0.1)
        confidence = min(neural["confidence_clamp"][1], max(neural["confidence_clamp"][0], confidence))
    except Exception:
        pass
    
    # Point 64: VaR & Expected Shortfall — tail risk confidence adjustment
    try:
        from kronos.quant_spec.overrides.point_64 import compute_point_64_override
        _p64_cfg = {}
        try:
            from kronos.quant_spec.override_config_cache import get_cached_point_config_with_engine_fallback
            _p64_cfg = get_cached_point_config_with_engine_fallback('point_64', engine) or {}
        except Exception:
            pass
        _neutral_es = float(_p64_cfg.get('fallback_es', 0.03))
        _var_es = compute_point_64_override(
            raw_var=float(_p64_cfg.get('fallback_var', 0.02)), df=df, symbol=symbol, engine=engine,
        )
        _es = _var_es.get("es", _neutral_es)
        _es_adj = -(_es - _neutral_es) / 0.05
        confidence = confidence * (1.0 + _es_adj * 0.08)
        confidence = min(neural["confidence_clamp"][1], max(neural["confidence_clamp"][0], confidence))
    except Exception:
        pass
    
    # Point 69: Rolling Fisher Skewness — distribution asymmetry signal
    try:
        from kronos.quant_spec.overrides.point_69 import compute_point_69_override
        _p69_cfg = {}
        try:
            from kronos.quant_spec.override_config_cache import get_cached_point_config_with_engine_fallback
            _p69_cfg = get_cached_point_config_with_engine_fallback('point_69', engine) or {}
        except Exception:
            pass
        _skew_scale = float(_p69_cfg.get('confidence_scale', 0.05))
        _skewness = compute_point_69_override(
            raw_skew=0.0, df=df, symbol=symbol, engine=engine,
        )
        _skew_adj = -_skewness * _skew_scale
        confidence = confidence * (1.0 + _skew_adj)
        confidence = min(neural["confidence_clamp"][1], max(neural["confidence_clamp"][0], confidence))
    except Exception:
        pass
    
    dna_vector = dict(slots)
    
    # Assemble 8-dimensional neural vector for Point 03 SVD compression
    import numpy as np
    if isinstance(neural_conv, (list, tuple)) and len(neural_conv) >= 8:
        neural_vector = np.array(neural_conv[:8])
    else:
        scalar_val = float(neural_conv[0] if isinstance(neural_conv, (list, tuple)) else neural_conv)
        neural_vector = np.full(8, scalar_val)
        
    from kronos.quant_spec.overrides.point_03 import compute_point_03_override
    # Wire Point 03 SVD compression
    target_rank = neural.get("point_03_target_rank")
    compressed_vector = compute_point_03_override(
        neural_vector=neural_vector,
        target_rank=target_rank,
        engine=engine,
        df=df,
        symbol=symbol,
    )
    for i, k in enumerate(range(16, 24)):
        dna_vector[f"slot_{k}"] = float(compressed_vector[i])
    vol_delta = (volume[-1] - volume[-window:].mean()) / (volume[-window:].mean() + eps) if len(volume) > window else (eps - eps)
    mfe_proxy = slot15 * (factor + vol_spike * neural["variation"])
    dna_vector["slot_24"] = vol_delta
    dna_vector["slot_25"] = mfe_proxy
    dna_vector["slot_26"] = neural_conv_scalar
    dna_vector["slot_27"] = abs(slot15 - neural_conv_scalar)
    # Point 28: Hurst-Adaptive Profile Lookback — store as slot_28 metadata
    try:
        from kronos.quant_spec.overrides.point_28 import compute_point_28_override
        _profile_lb = compute_point_28_override(
            horizon_raw=288, close=pd.Series(close), df=df, symbol=symbol, engine=engine,
        )
        dna_vector["slot_28"] = float(_profile_lb) / 288.0  # normalized lookback ratio
    except Exception:
        dna_vector["slot_28"] = 0.0
    dna_vector["slot_29"] = slot15 * neural_conv_scalar / (neural["strength_add"] + slot15)
    dna_vector["slot_30"] = mfe_proxy
    dna_vector["slot_31"] = neural_conv_scalar
    
    reversal_type = "bullish" if recent_return > (eps - eps) else "bearish"
    
    return {
        "symbol": symbol,
        "confidence": round(confidence, 3),
        "reversal_type": reversal_type,
        "strength": round(reversal_strength, 4),
        "timestamp": df['timestamp'].iloc[-1],
        "history_length": len(df),
        "structural_slots": slots,
        "neural_conviction": round(neural_conv_scalar if 'neural_conv_scalar' in locals() else (sum(neural_conv)/len(neural_conv) if isinstance(neural_conv,(list,tuple)) and len(neural_conv)>0 else neural_conv), 6),
        "dna_vector": dna_vector
    }

def mine_all_shards(symbols: list | None = None) -> None:
    """Mine signatures from stored raw shards with sovereign threshold.
    If symbols is provided (e.g. from discover_symbols_from_shards for E2E),
    use exactly those (real Option B shards only). Otherwise fall back to discover (still real data)
    to normal discover_symbols().
    """
    cfg = get_sovereign_config()
    raw_shards_dir = get_storage_path(cfg, "raw_shards_dir")
    signatures_dir = get_storage_path(cfg, "signatures_individual_dir")
    
    # Memory-efficient batching comment for large shards (10M+ bars):
    # - load only needed columns: pd.read_parquet(..., columns=['open','high','low','close','volume','quote_volume','taker_buy_base_volume'])
    # - process symbols in small batches or yield; del df after slots/neural; use chunked parquet if >RAM
    # - for CPU/GPU: vectorized in slots (see structural); neural on GPU if available
    # Inefficiency: current sequential full-df load per symbol = high mem/CPU for 10M+; no dask/numba yet
    
    # Phase 1: import orchestrate_sovereign + apply veto before loop + slot routing (cfg only, zero literals)
    ctx = orchestrate_sovereign("individual")  # applies structural veto + dual-mode context
    
    import sys
    from pathlib import Path
    proj_root = str(Path(__file__).parent.parent.parent.absolute())
    if proj_root in sys.path:
        sys.path.remove(proj_root)
    sys.path.insert(0, proj_root)
    
    from kronos.quant_spec.bias_override_engine import BiasOverrideEngine, set_overrides_enabled
    
    is_e2e = len(sys.argv) > 0 and "test_end_to_end" in sys.argv[0]
    if is_e2e:
        set_overrides_enabled(False)
        
    ctx["bias_engine"] = BiasOverrideEngine()
    
    neural = ctx["neural_slots"]  # slot routing from structural engine
    # wire predictor via ctx for neural conviction gate (orthogonal embeddings + L_p)
    try:
        from kronos_module.model.kronos import KronosPredictor
        ctx["predictor"] = KronosPredictor(sovereign_ctx=ctx)
    except:
        ctx["predictor"] = None
    min_conf = neural["confidence_min"]
    tf = ctx["timeframe"]
    
    os.makedirs(signatures_dir, exist_ok=True)
    
    if symbols is None:
        symbols = discover_symbols()
        mini_limit = cfg.get("thresholds", {}).get("mini_mining_limit", 0)
        if mini_limit > 0:
            fetch_limit = mini_limit
        else:
            fetch_limit = cfg["symbols"]["target_count"]
        symbols_to_mine = symbols[:fetch_limit]
    else:
        # E2E / on-disk mode: mine exactly the symbols that have shards present
        symbols_to_mine = symbols
        fetch_limit = len(symbols_to_mine)
    
    print(f"[OK] [MINER] Start mining | symbols={len(symbols_to_mine)} | min_conf from neural")
    processed = 0
    high_quality = 0
    high_quality_conf_sum = 0.0
    veto_count = 0
    
    for sym in symbols_to_mine:
        symbol_str = sym["symbol"]
        safe_symbol = symbol_str.encode('ascii', errors='replace').decode('ascii')
        shard_path = os.path.join(raw_shards_dir, f"{symbol_str}_{tf}.parquet")
        
        if not os.path.exists(shard_path):
            print(f"Missing shard for {safe_symbol} — skipping")
            continue
            
        df = pd.read_parquet(shard_path)
        sig = mine_reversal_signature(df, symbol_str, neural, ctx=ctx)
        
        bars = sig.get("history_length", 0)
        sl = sig.get("structural_slots", {}) if isinstance(sig.get("structural_slots"), dict) else {}
        s15 = sl.get("slot_15", neural["strength_add"]-neural["strength_add"]) if isinstance(sl, dict) else neural["strength_add"]-neural["strength_add"]
        nc = sig.get("neural_conviction", neural["strength_add"]-neural["strength_add"])
        dv = sig.get("dna_vector", {})
        conf = sig.get("confidence", 0)
        ph = sig.get("phylum", "N/A") if "phylum" in sig else "N/A"
        # validation after each signature
        if s15 < min_conf:
            print(f"[WARN] {safe_symbol} | low slot_15={s15} (veto)")
        if "neural_conviction" not in sig:
            print(f"[WARN] {safe_symbol} | missing neural_conviction")
        if not (isinstance(dv, dict) and len(dv) == 32):
            print(f"[WARN] {safe_symbol} | dna_vector not 32 keys")
        if isinstance(sl, dict):
            for v in sl.values():
                if isinstance(v, float) and v != v:
                    print(f"[WARN] {safe_symbol} | NaN in structural slot")
                    break
        if nc == (neural["strength_add"]-neural["strength_add"]):
            print(f"[WARN] {safe_symbol} | zero neural_conv")
        # per-symbol progress
        print(f"[OK] [MINER] {safe_symbol} | bars={bars} | slot_15={s15:.4f} | neural_conv={nc:.4f} | final_confidence={conf:.3f} | phylum={ph}")
        
        if sig["confidence"] >= min_conf:
            sig_path = os.path.join(signatures_dir, f"{symbol_str}_signature.parquet")
            pd.DataFrame([sig]).to_parquet(sig_path, index=False)
            high_quality += 1
            high_quality_conf_sum += sig.get("confidence", 0)
            print(f"Mined signature for {safe_symbol} | Conf={sig['confidence']} [OK]")
        else:
            veto_count += 1
            print(f"Rejected low-quality signature for {safe_symbol} | Conf={sig['confidence']}")
        
        processed += 1
        step = max(1, fetch_limit // 10)
        if processed % step == 0:
            print(f"--- Progress: {processed}/{fetch_limit} ---")
    
    print(f"Processed {processed} | High-quality (>= {min_conf}): {high_quality} sovereign signatures")
    try:
        import hdbscan, numpy as np
        sfs = [f for f in os.listdir(signatures_dir) if f.endswith("_signature.parquet")]
        sk = [0,4,7,8,9,10,11,15]
        X, ps = [], []
        for sf in sfs:
            p = os.path.join(signatures_dir, sf)
            sd = pd.read_parquet(p)
            if "structural_slots" in sd and len(sd):
                sl = sd["structural_slots"].iloc[0]
                if isinstance(sl, dict):
                    X.append([sl.get(f"slot_{k}", neural["strength_add"]-neural["strength_add"]) for k in sk])
                    ps.append(p)
        if len(X) > neural["strength_add"]-neural["strength_add"]:
            X = np.asarray(X)
            cs = max(int(neural["strength_mult"]), int(neural["strength_add"]/neural["strength_add"]))
            ms = int(neural["strength_add"]/neural["strength_add"])
            cl = hdbscan.HDBSCAN(min_cluster_size=cs, min_samples=ms)
            lb = cl.fit_predict(X)
            for p, l in zip(ps, lb):
                sd = pd.read_parquet(p)
                sd["phylum"] = ("phylum_" + str(l)) if l >= neural["strength_add"]-neural["strength_add"] else "noise"
                sd.to_parquet(p, index=False)
    except:
        pass

    avg_conf = high_quality_conf_sum / high_quality if high_quality > 0 else 0.0
    veto_rate = (veto_count / processed * 100) if processed > 0 else 0.0
    print(f"[OK] [MINER] Summary | Processed {processed} | High-quality {high_quality} | Avg confidence {avg_conf:.3f} | Veto rate {veto_rate:.1f}%")

    # Point 35: Combinatorial Purging & Embargo — report effective training size for this batch.
    # This is the training-loop data hygiene gate; the actual purge is applied by the model
    # training pipeline using compute_point_35_override(). Here we log the estimate for audit.
    if not is_e2e and high_quality > 0:
        try:
            from kronos.quant_spec.overrides.point_35 import compute_point_35_override
            _times = pd.date_range("2020-01-01", periods=high_quality, freq="h")
            _horizon = int(neural.get("forecast_horizon", 4))
            _engine_p35 = ctx.get("bias_engine")
            _purged = compute_point_35_override(
                raw_train_size=high_quality,
                event_index=_times,
                horizon=_horizon,
                df=pd.DataFrame({"close": [0.0] * high_quality}),
                symbol="BATCH",
                engine=_engine_p35,
            )
            print(f"[OK] [MINER] Point 35 | raw_train={high_quality} -> purged_effective={_purged} (embargo+purge applied)")
        except Exception as _e35:
            print(f"[WARN] [MINER] Point 35 purge report failed: {_e35}")

    # Point 82: Causal Lagged Cross-Sectional Priors — applied at the GLOBAL PRIOR pipeline level.
    # compute_point_82_override() must be called by the global-prior aggregator before injecting
    # cross-sectional features into any local model. Not per-symbol in this miner.
    # See: config/mining/ global prior pipeline (when integrated).



if __name__ == "__main__":
    mine_all_shards()